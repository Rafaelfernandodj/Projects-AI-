rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow Anyone to read/write for custom simple email session flow during MVP
    match /users/{userId} {
      allow read, write, create, update: if true;
    }

    match /users/{userId}/{allPaths=**} {
      allow read, write, create, update, delete: if true;
    }

    match /profiles/{profileId} {
      allow read, write, create, update: if true;
    }

    match /profiles/{profileId}/{allPaths=**} {
      allow read, write, create, update, delete: if true;
    }

    match /manualAccess/{accessId} {
      allow read, write, create, update: if true;
    }

    match /manualAccess/{accessId}/{allPaths=**} {
      allow read, write, create, update, delete: if true;
    }

    match /schools/{schoolId} {
      allow read, write: if true;
    }
  }
}
